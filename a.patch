From: Admirepowered <admire1971@outlook.com>
Date: Sat, 9 May 2026 23:38:44 +0800
Subject: [PATCH] fix build warnings

---
 kernel/linux/include/linux/fs.h |  21 ++++-
 kernel/patch/android/userd.c    | 131 ++++++++++++++++++++++----------
 2 files changed, 106 insertions(+), 46 deletions(-)

diff --git a/kernel/linux/include/linux/fs.h b/kernel/linux/include/linux/fs.h
index d566df3d..5de7a32f 100644
--- a/kernel/linux/include/linux/fs.h
+++ b/kernel/linux/include/linux/fs.h
@@ -357,15 +357,21 @@ static inline loff_t vfs_llseek(struct file *file, loff_t offset, int whence)
     kfunc_direct_call(vfs_llseek, file, offset, whence);
 }
 
-/* Directory iteration context (kernel 3.11+).
- * Actor signature: int return (4.x) or bool return (5.0+) — both are ABI-compatible
- * on arm64 for 0/1 values, so we use the 5.0+ bool form to satisfy the compiler.
+/* Directory iteration context.
+ * Linux < 6.1 uses an int actor, while Linux 6.1+ uses a bool actor.
+ * Keep both layouts so callers can use the signature that matches the
+ * target kernel without incompatible function pointer assignments.
  */
 struct dir_context {
     bool (*actor)(struct dir_context *, const char *, int, loff_t, u64, unsigned int);
     loff_t pos;
 };
 
+struct dir_context_int {
+    int (*actor)(struct dir_context_int *, const char *, int, loff_t, u64, unsigned int);
+    loff_t pos;
+};
+
 extern int kfunc_def(iterate_dir)(struct file *, struct dir_context *);
 
 static inline int iterate_dir(struct file *file, struct dir_context *ctx)
@@ -375,10 +381,17 @@ static inline int iterate_dir(struct file *file, struct dir_context *ctx)
     return 0; /* symbol not resolved; caller checks result via its context */
 }
 
+static inline int iterate_dir_int(struct file *file, struct dir_context_int *ctx)
+{
+    kfunc_call(iterate_dir, file, (struct dir_context *)ctx);
+    kfunc_not_found();
+    return 0; /* symbol not resolved; caller checks result via its context */
+}
+
 static inline void putname(struct filename *name)
 {
     kfunc_direct_call_void(putname, name);
     // kfunc_direct_call_void(final_putname, name);
 }
 
-#endif
\ No newline at end of file
+#endif
diff --git a/kernel/patch/android/userd.c b/kernel/patch/android/userd.c
index bd1991aa..a03207fa 100644
--- a/kernel/patch/android/userd.c
+++ b/kernel/patch/android/userd.c
@@ -517,6 +517,15 @@ struct apk_inner_ctx {
     const char *package;
 };
 
